# RelayForge client configuration
#
# Copy this file to .env when you want local builds to target a specific backend.
# The shared config accepts these explicit contract names across web, admin, and desktop builds.

API_BASE_URL=http://localhost:8080/api/v1
WS_URL=ws://localhost:8081/ws
LIVEKIT_URL=ws://localhost:7880
MEDIA_BASE_URL=http://localhost:8082/api/v1

# Legacy aliases remain supported for compatibility with older Vite-only setups.
# VITE_API_URL=http://localhost:8080/api/v1
# VITE_WS_URL=ws://localhost:8081/ws
# VITE_LIVEKIT_URL=ws://localhost:7880
# VITE_MEDIA_URL=http://localhost:8082/api/v1
